{
  "manifest_version": 3,
  "name": "Neuro-Inclusive Web Interface",
  "version": "1.0",
  "description": "An AI-powered extension to simplify layouts and adjust visual elements for cognitive accessibility.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Cognitive Accessibility Controls"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["styles/accessibility.css"],
      "js": ["scripts/content.js"],
      "run_at": "document_start"
    }
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ]
}
